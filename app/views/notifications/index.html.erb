<% content_for(:title, "Notifications") %>

<main class="min-h-[calc(100vh-4rem)] py-8 sm:py-12 px-4 sm:px-6 pb-32">
  <div class="max-w-3xl mx-auto">
    <%= turbo_stream_from Current.user, :notifications %>

    <header class="mb-4">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900">Notifications</h1>
      <p class="mt-2 text-sm text-gray-600">Updates on the reports you've submitted.</p>
    </header>

    <%= render "list", user: Current.user %>
  </div>
</main>
