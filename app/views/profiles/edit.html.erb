<% content_for(:title, t(".title")) %>

<main class="min-h-[calc(100vh-4rem)] py-8 sm:py-12 px-4 sm:px-6">
  <div class="max-w-xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
      <p class="mt-2 text-base text-gray-600"><%= t(".subtitle") %></p>
    </header>

    <%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "space-y-8" do |form| %>
      <% if @user.errors.any? %>
        <div role="alert" class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
          <p class="font-semibold mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# ─── Contact methods ─── %>
      <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
        <h2 class="text-lg font-semibold text-gray-900"><%= t(".contact_heading") %></h2>
        <p class="mt-1.5 text-sm text-gray-600"><%= t(".contact_intro") %></p>

        <div class="mt-6 space-y-5">
          <div>
            <%= form.label :email, t(".email_label"), class: "block text-sm font-medium text-gray-700" %>
            <%= form.email_field :email,
                  autocomplete: "email",
                  inputmode: "email",
                  placeholder: "you@example.com",
                  class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="mt-1.5 text-xs text-gray-500"><%= t(".email_hint") %></p>
          </div>

          <div>
            <%= form.label :phone, t(".phone_label"), class: "block text-sm font-medium text-gray-700" %>
            <%= form.telephone_field :phone,
                  autocomplete: "tel",
                  inputmode: "tel",
                  placeholder: "(555) 555-5555",
                  class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="mt-1.5 text-xs text-gray-500"><%= t(".phone_hint") %></p>
          </div>
        </div>
      </section>

      <%# ─── Password change ─── %>
      <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
        <h2 class="text-lg font-semibold text-gray-900"><%= t(".password_heading") %></h2>
        <p class="mt-1.5 text-sm text-gray-600"><%= t(".password_intro") %></p>

        <div class="mt-6 space-y-5">
          <div>
            <%= form.label :password, t(".new_password_label"), class: "block text-sm font-medium text-gray-700" %>
            <%= form.password_field :password,
                  autocomplete: "new-password",
                  minlength: User::PASSWORD_MIN_LENGTH,
                  maxlength: 72,
                  class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="mt-1.5 text-xs text-gray-500"><%= t(".new_password_hint") %></p>
          </div>

          <div>
            <%= form.label :password_confirmation, t(".new_password_confirmation_label"), class: "block text-sm font-medium text-gray-700" %>
            <%= form.password_field :password_confirmation,
                  autocomplete: "new-password",
                  maxlength: 72,
                  class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>
      </section>

      <%# ─── Current password confirmation ─── %>
      <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
        <h2 class="text-lg font-semibold text-gray-900"><%= t(".current_password_heading") %></h2>
        <p class="mt-1.5 text-sm text-gray-600"><%= t(".current_password_hint") %></p>

        <div class="mt-6">
          <%= form.label :current_password, t(".current_password_label"), class: "block text-sm font-medium text-gray-700" %>
          <%= form.password_field :current_password,
                required: true,
                autocomplete: "current-password",
                maxlength: 72,
                class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
      </section>

      <%= form.submit t(".submit"),
            class: "w-full rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-700 transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    <% end %>
  </div>
</main>
