<% content_for(:title, "Forgot your password") %>

<main class="min-h-[calc(100vh-4rem)] py-8 sm:py-12 px-4 sm:px-6">
  <div class="max-w-md mx-auto">
    <div class="text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">Forgot your password?</h1>
      <p class="mt-3 text-base text-gray-600">Enter the email address on your account and we'll send you a reset link. Password reset by phone isn't supported yet.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
      <%= form_with url: passwords_path, local: true, class: "space-y-6" do |form| %>
        <div>
          <%= form.label :email, "Email address", class: "block text-sm font-medium text-gray-700" %>
          <%= form.email_field :email,
                required: true,
                autofocus: true,
                autocomplete: "username",
                inputmode: "email",
                value: params[:email],
                placeholder: "you@example.com",
                class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>

        <%= form.submit "Email reset instructions",
              class: "w-full rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-700 transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
      <% end %>
    </div>

    <p class="mt-6 text-center text-sm text-gray-600">
      <%= link_to "Back to sign in", new_session_path, class: "font-semibold text-blue-600 hover:text-blue-700" %>
    </p>
  </div>
</main>
