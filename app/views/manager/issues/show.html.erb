<% content_for(:title, "Report") %>

<header class="mb-6 flex items-start justify-between gap-4">
  <div>
    <%= link_to "← Back to reports", manager_issues_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900">
      <%= @issue.title.presence || @issue.category.name %>
    </h1>
    <p class="mt-1 text-sm text-gray-500">
      Reported <%= l(@issue.created_at, format: :long) %>
    </p>
  </div>
  <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700 shrink-0">
    <%= @issue.category.name %>
  </span>
</header>

<div class="grid md:grid-cols-2 gap-6">
  <section class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
    <% if @issue.photo.attached? %>
      <%= image_tag @issue.photo.variant(resize_to_limit: [ 1200, 1200 ]),
            class: "w-full h-auto", alt: "" %>
    <% else %>
      <div class="px-6 py-12 text-center text-sm text-gray-500">No photo attached.</div>
    <% end %>
  </section>

  <section class="space-y-5">
    <div class="bg-white rounded-2xl border border-gray-200 p-5">
      <h3 class="text-xs font-medium uppercase tracking-wider text-gray-500">Location</h3>
      <p class="mt-2 text-sm text-gray-900"><%= @issue.address.presence || "—" %></p>
      <p class="mt-1 text-xs text-gray-500">
        <%= number_with_precision(@issue.latitude, precision: 6) %>,
        <%= number_with_precision(@issue.longitude, precision: 6) %>
      </p>
      <%= link_to "Open in map ↗",
            "https://www.openstreetmap.org/?mlat=#{@issue.latitude}&mlon=#{@issue.longitude}&zoom=18",
            target: "_blank", rel: "noopener",
            class: "mt-2 inline-block text-sm font-semibold text-blue-600 hover:text-blue-700" %>
    </div>

    <% if @issue.notes.present? %>
      <div class="bg-white rounded-2xl border border-gray-200 p-5">
        <h3 class="text-xs font-medium uppercase tracking-wider text-gray-500">Notes</h3>
        <p class="mt-2 text-sm text-gray-900 whitespace-pre-line"><%= @issue.notes %></p>
      </div>
    <% end %>

    <div class="bg-white rounded-2xl border border-gray-200 p-5">
      <h3 class="text-xs font-medium uppercase tracking-wider text-gray-500">Reporter</h3>
      <p class="mt-2 text-sm text-gray-900"><%= @issue.user.display_name %></p>
    </div>
  </section>
</div>
