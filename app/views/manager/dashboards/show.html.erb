<% content_for(:title, "Dashboard") %>

<header class="mb-8">
  <h1 class="text-3xl font-bold tracking-tight text-gray-900">Dashboard</h1>
  <p class="mt-2 text-sm text-gray-600">Your team's activity at a glance.</p>
</header>

<%
  cards = [
    ["Active officers",    @stats[:officers]],
    ["Total reports",      @stats[:issues_total]],
    ["Reports (24h)",      @stats[:issues_24h]],
    ["Reports (7d)",       @stats[:issues_7d]]
  ]
%>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
  <% cards.each do |label, value| %>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium uppercase tracking-wider text-gray-500"><%= label %></p>
      <p class="mt-2 text-3xl font-bold text-gray-900"><%= number_with_delimiter(value) %></p>
    </div>
  <% end %>
</div>

<div class="grid md:grid-cols-2 gap-6 mb-10">
  <%# Officer locations — latest known position per officer %>
  <section class="bg-white rounded-2xl border border-gray-200 p-6"
           data-controller="officer-map">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Officer locations</h2>
        <p class="mt-1 text-sm text-gray-600">Latest known position per officer (last 24h).</p>
      </div>
      <span class="text-xs text-gray-500"><%= @officer_locations.size %> on shift</span>
    </div>

    <% if @officer_locations.any? %>
      <div data-officer-map-target="map" class="mt-4 h-64 rounded-lg border border-gray-200 overflow-hidden"></div>
      <ul class="mt-4 divide-y divide-gray-100 text-sm">
        <% @officer_locations.each do |loc| %>
          <%
            minutes_ago = ((Time.current - loc.recorded_at) / 60).round
            on_shift = minutes_ago <= 30
          %>
          <li class="py-2 flex items-center justify-between gap-3"
              data-officer-map-target="officer"
              data-lat="<%= loc.latitude %>"
              data-lng="<%= loc.longitude %>"
              data-name="<%= loc.user.display_name %>"
              data-ago="<%= time_ago_in_words(loc.recorded_at) %>">
            <div class="min-w-0">
              <p class="font-medium text-gray-900 truncate"><%= loc.user.display_name %></p>
              <p class="text-xs text-gray-500">
                <%= number_with_precision(loc.latitude, precision: 4) %>,
                <%= number_with_precision(loc.longitude, precision: 4) %>
              </p>
            </div>
            <span class="shrink-0 inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-medium <%= on_shift ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-600' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= on_shift ? 'bg-green-500' : 'bg-gray-400' %>"></span>
              <%= time_ago_in_words(loc.recorded_at) %> ago
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="mt-4 rounded-lg border border-dashed border-gray-300 bg-gray-50 px-4 py-8 text-center text-sm text-gray-500">
        No officers have reported a location in the last 24 hours.
      </div>
    <% end %>
  </section>

  <%# Schedules — placeholder %>
  <section class="bg-white rounded-2xl border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900">Schedules</h2>
    <p class="mt-1 text-sm text-gray-600">Assign shifts and track coverage.</p>
    <div class="mt-4 rounded-lg border border-dashed border-gray-300 bg-gray-50 px-4 py-8 text-center text-sm text-gray-500">
      Coming soon.
    </div>
  </section>

  <%# KPIs — placeholder %>
  <section class="bg-white rounded-2xl border border-gray-200 p-6 md:col-span-2">
    <h2 class="text-lg font-semibold text-gray-900">Performance metrics</h2>
    <p class="mt-1 text-sm text-gray-600">Define KPIs to evaluate officer performance.</p>
    <div class="mt-4 rounded-lg border border-dashed border-gray-300 bg-gray-50 px-4 py-8 text-center text-sm text-gray-500">
      Coming soon.
    </div>
  </section>
</div>

<section class="bg-white rounded-2xl border border-gray-200">
  <header class="px-5 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900">Recent reports</h2>
    <%= link_to "View all →", manager_issues_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-700" %>
  </header>
  <% if @recent_issues.any? %>
    <ul class="divide-y divide-gray-100">
      <% @recent_issues.each do |issue| %>
        <li class="px-5 py-3 flex items-center justify-between gap-3 text-sm">
          <div class="min-w-0">
            <%= link_to issue.title.presence || issue.category.name, manager_issue_path(issue),
                  class: "font-medium text-gray-900 hover:text-blue-700 truncate block" %>
            <p class="text-gray-500 text-xs truncate"><%= issue.category.name %> · <%= issue.address.presence || "no address" %></p>
          </div>
          <time class="text-gray-500 text-xs shrink-0" datetime="<%= issue.created_at.iso8601 %>">
            <%= time_ago_in_words(issue.created_at) %> ago
          </time>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="px-5 py-8 text-center text-sm text-gray-500">No reports yet.</p>
  <% end %>
</section>
