<% content_for(:title, "Edit category") %>

<div class="max-w-xl">
  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Edit category</h1>
    <p class="mt-2 text-sm text-gray-600"><%= @category.name %></p>
  </header>
  <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8">
    <%= render "form", category: @category %>
  </div>
</div>
