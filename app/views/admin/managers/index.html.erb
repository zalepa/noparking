<% content_for(:title, "Managers") %>

<header class="mb-6 flex items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Managers</h1>
    <p class="mt-2 text-sm text-gray-600">Managers oversee enforcement officers and their schedules.</p>
  </div>
  <%= link_to "New manager", new_admin_manager_path,
        class: "inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
</header>

<div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
  <% if @managers.any? %>
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
        <tr>
          <th class="text-left px-5 py-3">Email</th>
          <th class="text-left px-5 py-3">Phone</th>
          <th class="text-left px-5 py-3">Created</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @managers.each do |manager| %>
          <tr>
            <td class="px-5 py-3"><%= manager.email.presence || "—" %></td>
            <td class="px-5 py-3"><%= manager.phone.presence || "—" %></td>
            <td class="px-5 py-3 text-gray-500"><%= manager.created_at.to_date.to_fs(:long) %></td>
            <td class="px-5 py-3 text-right space-x-3 whitespace-nowrap">
              <%= link_to "Edit", edit_admin_manager_path(manager), class: "text-blue-600 hover:text-blue-700 font-medium" %>
              <%= button_to "Delete", admin_manager_path(manager), method: :delete,
                    form: { data: { turbo_confirm: "Delete #{manager.display_name}?" }, class: "inline" },
                    class: "text-red-600 hover:text-red-700 font-medium cursor-pointer bg-transparent border-0 p-0" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-8 text-center text-sm text-gray-500">No managers yet.</p>
  <% end %>
</div>
