<%
  nav_items = [
    [admin_root_path,        "Dashboard",  controller_name == "dashboards"],
    [admin_managers_path,    "Managers",   controller_name == "managers"],
    [admin_categories_path,  "Categories", controller_name == "categories"]
  ]
%>
<aside class="hidden lg:flex lg:flex-col fixed inset-y-0 left-0 w-64 bg-white border-r border-gray-200 z-40">
  <div class="h-16 flex items-center px-6 border-b border-gray-200">
    <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
      <%= render "pages/logo", size: "w-7 h-7" %>
      <span class="font-semibold tracking-tight"><%= app_name %> <span class="text-gray-400 font-normal">Admin</span></span>
    <% end %>
  </div>
  <nav class="flex-1 px-3 py-6 space-y-1">
    <% nav_items.each do |path, label, active| %>
      <%= link_to label, path,
            class: "block rounded-lg px-3 py-2 text-sm font-medium #{active ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-100'}" %>
    <% end %>
  </nav>
  <div class="border-t border-gray-200 p-4 space-y-2 text-sm">
    <p class="text-gray-500 truncate"><%= Current.user.display_name %></p>
    <%= link_to "Back to site", root_path, class: "block text-gray-700 hover:text-gray-900" %>
    <%= button_to "Sign out", session_path, method: :delete,
          class: "w-full text-left text-gray-700 hover:text-gray-900 cursor-pointer" %>
  </div>
</aside>

<%# Mobile top bar %>
<header class="lg:hidden sticky top-0 z-40 bg-white border-b border-gray-200 px-4 h-14 flex items-center justify-between">
  <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
    <%= render "pages/logo", size: "w-6 h-6" %>
    <span class="font-semibold"><%= app_name %> Admin</span>
  <% end %>
  <%= link_to "Site", root_path, class: "text-sm text-gray-700" %>
</header>
<div class="lg:hidden border-b border-gray-200 bg-white px-2 py-2 flex gap-1 overflow-x-auto">
  <% nav_items.each do |path, label, active| %>
    <%= link_to label, path,
          class: "shrink-0 rounded-lg px-3 py-1.5 text-sm font-medium #{active ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-100'}" %>
  <% end %>
</div>
