<%= form_with model: [:admin, resolution_type], local: true, class: "space-y-5" do |form| %>
  <% if resolution_type.errors.any? %>
    <div role="alert" class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <p class="font-semibold mb-1">Please fix the following:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% resolution_type.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name,
          required: true,
          maxlength: 120,
          class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.label :position, "Display order", class: "block text-sm font-medium text-gray-700" %>
    <%= form.number_field :position,
          min: 1,
          class: "mt-1.5 block w-32 rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div class="flex items-center gap-2">
    <%= form.check_box :active, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
    <%= form.label :active, "Show in resolution form", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex items-center justify-end gap-3 pt-2">
    <%= link_to "Cancel", admin_resolution_types_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
    <%= form.submit (resolution_type.persisted? ? "Save changes" : "Create resolution type"),
          class: "rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
