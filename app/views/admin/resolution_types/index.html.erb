<% content_for(:title, "Resolution types") %>

<header class="mb-6 flex items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Resolution types</h1>
    <p class="mt-2 text-sm text-gray-600">Officers choose one of these when closing out a reported issue.</p>
  </div>
  <%= link_to "New resolution type", new_admin_resolution_type_path,
        class: "inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
</header>

<div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
  <% if @resolution_types.any? %>
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
        <tr>
          <th class="text-left px-5 py-3 w-20">#</th>
          <th class="text-left px-5 py-3">Name</th>
          <th class="text-left px-5 py-3">Status</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @resolution_types.each do |rt| %>
          <tr>
            <td class="px-5 py-3 text-gray-500"><%= rt.position %></td>
            <td class="px-5 py-3 font-medium text-gray-900"><%= rt.name %></td>
            <td class="px-5 py-3">
              <% if rt.active? %>
                <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">Active</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">Hidden</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-right space-x-3 whitespace-nowrap">
              <%= link_to "Edit", edit_admin_resolution_type_path(rt), class: "text-blue-600 hover:text-blue-700 font-medium" %>
              <%= button_to "Delete", admin_resolution_type_path(rt), method: :delete,
                    form: { data: { turbo_confirm: "Delete \"#{rt.name}\"?" }, class: "inline" },
                    class: "text-red-600 hover:text-red-700 font-medium cursor-pointer bg-transparent border-0 p-0" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-8 text-center text-sm text-gray-500">No resolution types yet.</p>
  <% end %>
</div>
