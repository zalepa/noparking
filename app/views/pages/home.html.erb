<% content_for(:title, t(".title")) %>
<% content_for(:marketing_nav, true) %>

<%# ═══════════════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════════════ %>
<section class="pt-20 sm:pt-24 pb-20 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <p class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-1.5 text-sm font-medium text-blue-700 mb-8">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <%= t(".hero.badge") %>
    </p>

    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-gray-900 leading-[1.1]">
      <%= t(".hero.heading_html") %>
    </h1>

    <p class="mt-6 text-lg text-gray-600 max-w-xl mx-auto leading-relaxed">
      <%= t(".hero.description_html") %>
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#how-it-works" class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 transition focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
        <%= t(".hero.cta_primary") %>
        <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </a>
      <a href="https://github.com" class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2">
        <%= render "pages/github_icon" %>
        <%= t(".hero.cta_github") %>
      </a>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════════════
     HOW IT WORKS
     ═══════════════════════════════════════════════════════════════════ %>
<section id="how-it-works" class="py-20 px-6 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900"><%= t(".how_it_works.heading") %></h2>
      <p class="mt-3 text-gray-600 max-w-lg mx-auto"><%= t(".how_it_works.subheading") %></p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <% t(".how_it_works.steps").each_with_index do |step, i| %>
        <div class="relative bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-sm mb-5"><%= i + 1 %></div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= step[:title] %></h3>
          <p class="text-gray-600 text-sm leading-relaxed"><%= step[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════════════
     FEATURES
     ═══════════════════════════════════════════════════════════════════ %>
<section id="features" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900"><%= t(".features.heading") %></h2>
      <p class="mt-3 text-gray-600 max-w-lg mx-auto"><%= t(".features.subheading") %></p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% t(".features.items").each do |feature| %>
        <div class="rounded-xl border border-gray-100 p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= feature_icon_path(feature[:key]) %>"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1"><%= feature[:title] %></h3>
          <p class="text-sm text-gray-600 leading-relaxed"><%= feature[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════════════
     USER ROLES
     ═══════════════════════════════════════════════════════════════════ %>
<section id="roles" class="py-20 px-6 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900"><%= t(".roles.heading") %></h2>
      <p class="mt-3 text-gray-600 max-w-lg mx-auto"><%= t(".roles.subheading") %></p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <% t(".roles.items").each do |role| %>
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-3 h-3 rounded-full <%= role_dot_class(role[:key]) %>"></div>
            <h3 class="text-lg font-semibold text-gray-900"><%= role[:name] %></h3>
          </div>
          <ul class="space-y-3">
            <% role[:capabilities].each do |item| %>
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <svg class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <%= item %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════════════
     CTA / GET STARTED
     ═══════════════════════════════════════════════════════════════════ %>
<section class="py-20 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl font-bold tracking-tight text-gray-900"><%= t(".cta.heading") %></h2>
    <p class="mt-4 text-gray-600 leading-relaxed"><%= t(".cta.description") %></p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="https://github.com" class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 transition">
        <%= render "pages/github_icon" %>
        <%= t(".cta.clone") %>
      </a>
      <a href="#" class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition">
        <%= t(".cta.docs") %>
      </a>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════════════
     FOOTER
     ═══════════════════════════════════════════════════════════════════ %>
<footer class="border-t border-gray-100 py-10 px-6">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
    <div class="flex items-center gap-2">
      <%= render "pages/logo", size: "w-5 h-5" %>
      <span class="font-medium text-gray-700"><%= app_name %></span>
    </div>
    <p><%= t(".footer.tagline") %></p>
  </div>
</footer>
