<li id="<%= dom_id(issue) %>" class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
  <% if issue.resolved? %>
    <% res = issue.resolution %>
    <div class="bg-green-50 border-b border-green-200 px-4 sm:px-5 py-3 flex items-center gap-3 flex-wrap">
      <span class="inline-flex items-center rounded-full bg-green-600 text-white px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider">Resolved</span>
      <span class="text-sm text-green-900">
        <%= res.resolution_type.name %> — <%= time_ago_in_words(res.created_at) %> ago
      </span>
    </div>
  <% elsif issue.assigned? %>
    <div class="bg-blue-50 border-b border-blue-200 px-4 sm:px-5 py-3 flex items-center gap-3 flex-wrap">
      <span class="inline-flex items-center rounded-full bg-blue-600 text-white px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider">Assigned</span>
      <span class="text-sm text-blue-900">
        An officer has been assigned — <%= time_ago_in_words(issue.assigned_at) %> ago
      </span>
    </div>
  <% else %>
    <div class="bg-amber-50 border-b border-amber-200 px-4 sm:px-5 py-3 flex items-center gap-3 flex-wrap">
      <span class="inline-flex items-center rounded-full bg-amber-500 text-white px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider">Open</span>
      <span class="text-sm text-amber-900">
        Awaiting an officer — reported <%= time_ago_in_words(issue.created_at) %> ago
      </span>
    </div>
  <% end %>

  <div class="flex flex-col sm:flex-row">
    <% if issue.photo.attached? %>
      <div class="sm:w-40 sm:h-40 w-full h-48 bg-gray-100 shrink-0">
        <%= image_tag issue.photo.variant(resize_to_fill: [ 400, 400 ]),
              class: "w-full h-full object-cover", alt: issue.title %>
      </div>
    <% end %>
    <div class="p-5 sm:p-6 flex-1">
      <div class="flex items-start justify-between gap-3">
        <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700">
          <%= issue.category.name %>
        </span>
        <time class="text-xs text-gray-500 shrink-0" datetime="<%= issue.created_at.iso8601 %>">
          <%= t("issues.index.submitted_on", date: l(issue.created_at, format: :long)) %>
        </time>
      </div>
      <h2 class="mt-2 text-lg font-semibold text-gray-900"><%= issue.title.presence || issue.category.name %></h2>
      <% if issue.notes.present? %>
        <p class="mt-2 text-sm text-gray-700 whitespace-pre-line"><%= issue.notes %></p>
      <% end %>
      <% if issue.address.present? %>
        <p class="mt-2 text-sm text-gray-600 flex items-start gap-1.5">
          <svg class="w-4 h-4 mt-0.5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span><%= issue.address %></span>
        </p>
      <% end %>
      <% if issue.resolved? && issue.resolution.note.present? %>
        <p class="mt-3 rounded-lg bg-green-50 border border-green-200 px-3 py-2 text-sm text-green-900 whitespace-pre-line">
          <%= issue.resolution.note %>
        </p>
      <% end %>
    </div>
  </div>
</li>
