<% content_for(:title, t(".title")) %>
<% content_for(:hide_report_button, true) %>

<main class="min-h-[calc(100vh-4rem)] px-4 sm:px-6 pb-10">
  <div class="max-w-xl mx-auto"
       data-controller="issue-wizard"
       data-issue-wizard-step-value="photo">

    <%# ─── Header: cancel + step indicator ─── %>
    <header class="flex items-center justify-between pt-6 pb-4">
      <%= link_to t(".cancel"), issues_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
      <span class="text-xs font-medium uppercase tracking-wider text-gray-500"
            data-issue-wizard-target="stepLabel"></span>
      <span class="w-12"></span>
    </header>

    <%# Progress dots %>
    <div class="flex items-center justify-center gap-2 mb-6" aria-hidden="true">
      <% %w[photo location details].each do |step| %>
        <span data-issue-wizard-target="dot"
              data-step="<%= step %>"
              class="h-2 w-2 rounded-full bg-gray-300 transition"></span>
      <% end %>
    </div>

    <%= form_with model: @issue, url: issues_path, local: true,
          class: "space-y-6",
          data: {
            issue_wizard_target: "form",
            controller: "camera location-picker",
            action: "submit->issue-wizard#beforeSubmit"
          } do |form| %>

      <% if @issue.errors.any? %>
        <div role="alert" class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
          <p class="font-semibold mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% @issue.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# ════════════════════════════════════════════════════════════
           STEP 1 — PHOTO
           ════════════════════════════════════════════════════════════ %>
      <section data-issue-wizard-target="panel" data-step="photo" class="space-y-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= t(".step_photo_title") %></h1>
          <p class="mt-1.5 text-sm text-gray-600"><%= t(".step_photo_subtitle") %></p>
        </div>

        <div class="relative aspect-[3/4] bg-gray-900 rounded-2xl overflow-hidden"
             data-camera-target="viewport">
          <video data-camera-target="video" autoplay playsinline muted
                 class="absolute inset-0 w-full h-full object-cover"></video>
          <img data-camera-target="preview"
               class="absolute inset-0 w-full h-full object-cover hidden" alt=""/>
          <div data-camera-target="error"
               class="absolute inset-0 flex items-center justify-center p-6 text-center text-white text-sm bg-gray-900/80 hidden">
            <%= t(".camera_unavailable") %>
          </div>
          <div data-camera-target="skipped"
               class="absolute inset-0 flex flex-col items-center justify-center text-gray-300 text-sm bg-gray-900 hidden">
            <svg class="w-10 h-10 mb-2 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l18 18M15 15v2a2 2 0 01-2 2H5a2 2 0 01-2-2V9a2 2 0 012-2h2m4 0h6a2 2 0 012 2v6"/></svg>
            <%= t(".photo_skipped") %>
          </div>
        </div>

        <canvas data-camera-target="canvas" class="hidden"></canvas>
        <%= file_field_tag :photo_file_fallback,
              accept: "image/*",
              class: "hidden",
              data: { camera_target: "fileInput", action: "change->camera#fileSelected" } %>
        <%= hidden_field_tag "issue[photo_data]", nil, data: { camera_target: "dataField" } %>

        <%# Live-state buttons %>
        <div data-camera-target="liveActions" class="space-y-3">
          <button type="button"
                  data-action="camera#capture"
                  data-camera-target="captureButton"
                  class="w-full rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-700 transition disabled:bg-blue-300 disabled:cursor-not-allowed">
            <%= t(".capture") %>
          </button>
          <div class="grid grid-cols-2 gap-3">
            <button type="button"
                    data-action="camera#triggerFileInput"
                    class="w-full rounded-lg border border-gray-300 bg-white px-6 py-3.5 text-base font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition">
              <%= t(".upload") %>
            </button>
            <button type="button"
                    data-action="camera#skip issue-wizard#advance"
                    class="w-full rounded-lg border border-gray-300 bg-white px-6 py-3.5 text-base font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition">
              <%= t(".skip") %>
            </button>
          </div>
        </div>

        <%# Post-capture buttons %>
        <div data-camera-target="capturedActions" class="grid grid-cols-2 gap-3 hidden">
          <button type="button"
                  data-action="camera#retake"
                  class="w-full rounded-lg border border-gray-300 bg-white px-6 py-3.5 text-base font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition">
            <%= t(".retake") %>
          </button>
          <button type="button"
                  data-action="issue-wizard#advance"
                  class="w-full rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-700 transition">
            <%= t(".next") %>
          </button>
        </div>

        <%# Fallback when camera unavailable %>
        <div data-camera-target="fallbackActions" class="hidden">
          <button type="button"
                  data-action="camera#triggerFileInput"
                  class="w-full rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-700 transition">
            <%= t(".upload_fallback") %>
          </button>
          <button type="button"
                  data-action="camera#skip issue-wizard#advance"
                  class="mt-3 w-full rounded-lg border border-gray-300 bg-white px-6 py-3.5 text-base font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition">
            <%= t(".skip") %>
          </button>
        </div>
      </section>

      <%# ════════════════════════════════════════════════════════════
           STEP 2 — LOCATION
           ════════════════════════════════════════════════════════════ %>
      <section data-issue-wizard-target="panel" data-step="location" class="space-y-4 hidden">
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= t(".step_location_title") %></h1>
          <p class="mt-1.5 text-sm text-gray-600"
             data-location-picker-target="instructions"><%= t(".step_location_subtitle") %></p>
        </div>

        <div class="relative">
          <div data-location-picker-target="map"
               class="w-full rounded-2xl overflow-hidden border border-gray-200 shadow-sm"
               style="height: 55vh; min-height: 340px;"></div>
          <div data-location-picker-target="loading"
               class="absolute inset-0 flex items-center justify-center rounded-2xl bg-white/80 text-sm text-gray-600">
            <%= t(".locating") %>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wider text-gray-500"><%= t(".address_label") %></p>
          <p class="mt-1 text-sm text-gray-900" data-location-picker-target="address"><%= t(".address_lookup") %></p>
        </div>

        <%= form.hidden_field :latitude,  data: { location_picker_target: "latitudeField" } %>
        <%= form.hidden_field :longitude, data: { location_picker_target: "longitudeField" } %>
        <%= form.hidden_field :address,   data: { location_picker_target: "addressField" } %>

        <div class="grid grid-cols-2 gap-3">
          <button type="button"
                  data-action="issue-wizard#back"
                  class="w-full rounded-lg border border-gray-300 bg-white px-6 py-3.5 text-base font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition">
            <%= t(".back") %>
          </button>
          <button type="button"
                  data-action="issue-wizard#advance"
                  data-issue-wizard-target="locationNext"
                  class="w-full rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-700 transition disabled:bg-blue-300 disabled:cursor-not-allowed"
                  disabled>
            <%= t(".next") %>
          </button>
        </div>
      </section>

      <%# ════════════════════════════════════════════════════════════
           STEP 3 — DETAILS
           ════════════════════════════════════════════════════════════ %>
      <section data-issue-wizard-target="panel" data-step="details" class="space-y-5 hidden">
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= t(".step_details_title") %></h1>
          <p class="mt-1.5 text-sm text-gray-600"><%= t(".step_details_subtitle") %></p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-20 h-20 rounded-lg bg-gray-100 overflow-hidden shrink-0 flex items-center justify-center text-gray-400">
              <img data-issue-wizard-target="reviewPhoto" class="w-full h-full object-cover hidden" alt=""/>
              <span data-issue-wizard-target="reviewPhotoEmpty" class="text-xs text-center px-2"><%= t(".review_no_photo") %></span>
            </div>
            <div class="text-sm">
              <p class="font-semibold text-gray-900"><%= t(".review_location") %></p>
              <p class="mt-0.5 text-gray-600" data-issue-wizard-target="reviewAddress">—</p>
            </div>
          </div>
        </div>

        <div>
          <%= form.label :category_id, t(".category_label"), class: "block text-sm font-medium text-gray-700" %>
          <%= form.select :category_id,
                options_from_collection_for_select(@categories, :id, :name, @issue.category_id),
                { prompt: t(".category_prompt") },
                required: true,
                class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-4 pr-10 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 appearance-none bg-white bg-no-repeat bg-[right_1rem_center] bg-[length:1.25rem] bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20d%3D%22M19%209l-7%207-7-7%22/%3E%3C/svg%3E')]" %>
        </div>

        <div>
          <%= form.label :title, t(".title_label"), class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_field :title,
                maxlength: 120,
                placeholder: t(".title_placeholder"),
                class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>

        <div>
          <%= form.label :notes, t(".notes_label"), class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :notes, rows: 4,
                maxlength: 2000,
                placeholder: t(".notes_placeholder"),
                class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>

        <div class="grid grid-cols-2 gap-3 pt-2">
          <button type="button"
                  data-action="issue-wizard#back"
                  class="w-full rounded-lg border border-gray-300 bg-white px-6 py-3.5 text-base font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition">
            <%= t(".back") %>
          </button>
          <%= form.submit t(".submit"),
                class: "w-full rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm hover:bg-blue-700 transition cursor-pointer" %>
        </div>
      </section>
    <% end %>
  </div>
</main>
