<% content_for(:title, t(".title")) %>

<main class="min-h-[calc(100vh-4rem)] py-8 sm:py-12 px-4 sm:px-6 pb-32">
  <div class="max-w-3xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
      <% if Current.user&.display_name.present? %>
        <p class="mt-2 text-sm text-gray-600">Signed in as <span class="font-medium text-gray-900"><%= Current.user.display_name %></span></p>
      <% end %>
    </header>

    <% if @issues.any? %>
      <ul class="space-y-4">
        <% @issues.each do |issue| %>
          <li class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="flex flex-col sm:flex-row">
              <% if issue.photo.attached? %>
                <div class="sm:w-40 sm:h-40 w-full h-48 bg-gray-100 shrink-0">
                  <%= image_tag issue.photo.variant(resize_to_fill: [ 400, 400 ]),
                        class: "w-full h-full object-cover", alt: issue.title %>
                </div>
              <% end %>
              <div class="p-5 sm:p-6 flex-1">
                <div class="flex items-start justify-between gap-3">
                  <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700">
                    <%= issue.category.name %>
                  </span>
                  <time class="text-xs text-gray-500 shrink-0" datetime="<%= issue.created_at.iso8601 %>">
                    <%= t(".submitted_on", date: l(issue.created_at, format: :long)) %>
                  </time>
                </div>
                <h2 class="mt-2 text-lg font-semibold text-gray-900"><%= issue.title.presence || issue.category.name %></h2>
                <% if issue.address.present? %>
                  <p class="mt-1 text-sm text-gray-600 flex items-start gap-1.5">
                    <svg class="w-4 h-4 mt-0.5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span><%= issue.address %></span>
                  </p>
                <% end %>
                <% if issue.notes.present? %>
                  <p class="mt-3 text-sm text-gray-700 whitespace-pre-line"><%= issue.notes %></p>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 sm:p-12 text-center">
        <div class="mx-auto w-14 h-14 rounded-full bg-blue-50 flex items-center justify-center mb-5">
          <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-3-3v6m9-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-gray-900"><%= t(".empty_title") %></h2>
        <p class="mt-3 text-gray-600 max-w-md mx-auto leading-relaxed"><%= t(".empty_body") %></p>
      </div>
    <% end %>
  </div>
</main>
