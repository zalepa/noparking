<% content_for(:title, t(".title")) %>

<main class="min-h-[calc(100vh-4rem)] py-8 sm:py-12 px-4 sm:px-6 pb-32">
  <div class="max-w-3xl mx-auto">
    <%= turbo_stream_from Current.user, :issues %>
    <header class="mb-6">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
    </header>

    <%= form_with url: issues_path, method: :get, local: true, data: { controller: "autosubmit" },
          class: "mb-6 flex flex-wrap items-center gap-3" do |form| %>
      <div class="flex items-center gap-2">
        <%= form.label :status, "Status", class: "text-sm font-medium text-gray-700" %>
        <%= form.select :status,
              [["All", "all"], ["Open", "open"], ["Assigned", "assigned"], ["Resolved", "resolved"]],
              { selected: @status },
              onchange: "this.form.requestSubmit()",
              class: "rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="flex items-center gap-2">
        <%= form.label :sort, "Sort", class: "text-sm font-medium text-gray-700" %>
        <%= form.select :sort,
              [["Newest first", "newest"], ["Oldest first", "oldest"]],
              { selected: @sort },
              onchange: "this.form.requestSubmit()",
              class: "rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <% if @status != "all" || @sort != "newest" %>
        <%= link_to "Clear", issues_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
      <% end %>
    <% end %>

    <% if @issues.any? %>
      <ul class="space-y-4">
        <% @issues.each do |issue| %>
          <%= render "issue_card", issue: issue %>
        <% end %>
      </ul>
    <% elsif @status == "all" && @resolved_issues.empty? %>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 sm:p-12 text-center">
        <div class="mx-auto w-14 h-14 rounded-full bg-blue-50 flex items-center justify-center mb-5">
          <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-3-3v6m9-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-gray-900"><%= t(".empty_title") %></h2>
        <p class="mt-3 text-gray-600 max-w-md mx-auto leading-relaxed"><%= t(".empty_body") %></p>
      </div>
    <% elsif @status != "all" %>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 text-center text-sm text-gray-600">
        No reports match this filter.
      </div>
    <% end %>

    <% if @resolved_issues.any? %>
      <details class="mt-8 group" data-controller="">
        <summary class="cursor-pointer select-none flex items-center justify-between rounded-2xl bg-white border border-gray-200 shadow-sm px-5 py-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            Resolved reports
            <span class="ml-1 inline-flex items-center rounded-full bg-gray-100 text-gray-700 px-2 py-0.5 text-xs font-medium"><%= @resolved_issues.size %></span>
          </span>
          <svg class="w-4 h-4 text-gray-500 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <ul class="space-y-4 mt-4">
          <% @resolved_issues.each do |issue| %>
            <%= render "issue_card", issue: issue %>
          <% end %>
        </ul>
      </details>
    <% end %>
  </div>
</main>
