<%
  distance_mi = local_assigns[:coordinates] ? issue.distance_miles_from(*coordinates) : nil
%>
<li data-officer-location-target="row"
    data-lat="<%= issue.latitude %>"
    data-lng="<%= issue.longitude %>">
  <%= link_to officer_issue_path(issue),
        class: "block px-5 py-4 hover:bg-gray-50 transition" do %>
    <div class="flex items-start gap-4">
      <% if issue.photo.attached? %>
        <%= image_tag issue.photo.variant(resize_to_fill: [ 160, 160 ]),
              class: "w-20 h-20 rounded-lg object-cover shrink-0", alt: "" %>
      <% else %>
        <div class="w-20 h-20 rounded-lg bg-gray-100 shrink-0 flex items-center justify-center text-xs text-gray-400">No photo</div>
      <% end %>
      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-1.5 min-w-0">
            <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700 truncate">
              <%= issue.category.name %>
            </span>
            <% if issue.assigned? %>
              <% mine = issue.assigned_to_id == Current.user.id %>
              <span class="inline-flex items-center rounded-full <%= mine ? 'bg-blue-600 text-white' : 'bg-amber-100 text-amber-800' %> px-2 py-0.5 text-xs font-medium shrink-0">
                <%= mine ? "Mine" : "Taken" %>
              </span>
            <% end %>
          </div>
          <span data-officer-location-target="distance"
                class="<%= distance_mi ? 'text-xs font-semibold text-gray-900 shrink-0 bg-gray-100 rounded-full px-2 py-0.5' : 'text-xs text-gray-500 shrink-0' %>">
            <% if distance_mi && distance_mi.finite? %>
              <%= number_with_precision(distance_mi, precision: distance_mi < 10 ? 1 : 0) %> mi
            <% else %>
              <%= time_ago_in_words(issue.created_at) %> ago
            <% end %>
          </span>
        </div>
        <h2 class="mt-1.5 text-sm font-semibold text-gray-900 truncate">
          <%= issue.title.presence || issue.category.name %>
        </h2>
        <% if issue.address.present? %>
          <p class="mt-0.5 text-xs text-gray-600 truncate"><%= issue.address %></p>
        <% end %>
      </div>
    </div>
  <% end %>
</li>
