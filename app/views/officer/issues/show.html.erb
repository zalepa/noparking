<% content_for(:title, "Report") %>

<%
  distance_mi = @coordinates ? @issue.distance_miles_from(*@coordinates) : nil
  back_path   = officer_issues_path(lat: @coordinates&.first, lng: @coordinates&.last)
  directions_url = "https://www.google.com/maps/dir/?api=1" \
                   "&destination=#{@issue.latitude},#{@issue.longitude}" \
                   "&travelmode=driving&dir_action=navigate"
%>

<header class="mb-6 flex items-start justify-between gap-4">
  <div>
    <%= link_to "← All reports", back_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
    <h1 class="mt-2 text-2xl font-bold tracking-tight text-gray-900">
      <%= @issue.title.presence || @issue.category.name %>
    </h1>
    <p class="mt-1 text-sm text-gray-500">
      Reported <%= time_ago_in_words(@issue.created_at) %> ago
      <% if distance_mi && distance_mi.finite? %>
        · <span class="font-semibold text-gray-900"><%= number_with_precision(distance_mi, precision: distance_mi < 10 ? 1 : 0) %> mi away</span>
      <% end %>
    </p>
  </div>
  <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700 shrink-0">
    <%= @issue.category.name %>
  </span>
</header>

<div class="grid grid-cols-1 lg:grid-cols-5 gap-5">
  <div class="lg:col-span-3 space-y-5">
    <% if @issue.photo.attached? %>
      <%= image_tag @issue.photo.variant(resize_to_limit: [ 1600, 1600 ]),
            class: "w-full rounded-2xl border border-gray-200", alt: "" %>
    <% else %>
      <div class="w-full aspect-video rounded-2xl bg-gray-100 border border-gray-200 flex items-center justify-center text-sm text-gray-400">
        No photo attached
      </div>
    <% end %>
  </div>

  <div class="lg:col-span-2 space-y-5">
    <% if @issue.resolved? %>
      <% res = @issue.resolution %>
      <div class="bg-green-50 rounded-2xl border border-green-200 p-5">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center rounded-full bg-green-600 text-white px-2 py-0.5 text-xs font-semibold uppercase tracking-wider">Resolved</span>
          <span class="text-xs text-green-800"><%= time_ago_in_words(res.created_at) %> ago</span>
        </div>
        <p class="mt-3 text-base font-semibold text-green-900"><%= res.resolution_type.name %></p>
        <% if res.note.present? %>
          <p class="mt-2 text-sm text-green-900 whitespace-pre-line"><%= res.note %></p>
        <% end %>
        <% if res.citation_number.present? %>
          <p class="mt-3 text-xs text-green-800"><span class="font-medium">Citation #:</span> <%= res.citation_number %></p>
        <% end %>
        <p class="mt-3 text-xs text-green-800">Closed by <%= res.user.display_name %></p>
      </div>
    <% elsif @issue.assigned? %>
      <% mine = @issue.assigned_to_id == Current.user.id %>
      <div class="rounded-2xl border p-5 <%= mine ? 'bg-blue-50 border-blue-200' : 'bg-amber-50 border-amber-200' %>">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center rounded-full <%= mine ? 'bg-blue-600' : 'bg-amber-600' %> text-white px-2 py-0.5 text-xs font-semibold uppercase tracking-wider">Assigned</span>
          <span class="text-xs <%= mine ? 'text-blue-800' : 'text-amber-800' %>"><%= time_ago_in_words(@issue.assigned_at) %> ago</span>
        </div>
        <p class="mt-3 text-sm <%= mine ? 'text-blue-900' : 'text-amber-900' %>">
          <% if mine %>
            You've taken this issue on.
          <% else %>
            Assigned to <%= @issue.assigned_to.display_name %>.
          <% end %>
        </p>
        <% if mine %>
          <div class="mt-4 flex flex-col gap-2">
            <%= link_to "Resolve this issue", new_officer_issue_resolution_path(@issue),
                  class: "block text-center rounded-lg bg-green-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700" %>
            <%= button_to "Release issue", officer_issue_assignment_path(@issue), method: :delete,
                  form: { data: { turbo_confirm: "Release this issue back to the open queue?" } },
                  class: "block w-full text-center rounded-lg bg-white border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= button_to "Take on this issue", officer_issue_assignment_path(@issue), method: :post,
            form: { class: "w-full" },
            class: "w-full block text-center rounded-2xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 cursor-pointer" %>
    <% end %>

    <div class="bg-white rounded-2xl border border-gray-200 p-5">
      <h3 class="text-xs font-medium uppercase tracking-wider text-gray-500">Location</h3>
      <p class="mt-2 text-sm text-gray-900"><%= @issue.address.presence || "—" %></p>
      <p class="mt-1 text-xs text-gray-500">
        <%= number_with_precision(@issue.latitude, precision: 6) %>,
        <%= number_with_precision(@issue.longitude, precision: 6) %>
      </p>
      <%= link_to "Start navigation →", directions_url,
            target: "_blank", rel: "noopener",
            class: "mt-3 inline-block rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
    </div>

    <% if @issue.notes.present? %>
      <div class="bg-white rounded-2xl border border-gray-200 p-5">
        <h3 class="text-xs font-medium uppercase tracking-wider text-gray-500">Notes from reporter</h3>
        <p class="mt-2 text-sm text-gray-900 whitespace-pre-line"><%= @issue.notes %></p>
      </div>
    <% end %>
  </div>
</div>
