<% content_for(:title, "Resolve issue") %>

<header class="mb-6">
  <%= link_to "← Back to report", officer_issue_path(@issue), class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
  <h1 class="mt-2 text-2xl font-bold tracking-tight text-gray-900">Resolve this issue</h1>
  <p class="mt-1 text-sm text-gray-600">
    <%= @issue.title.presence || @issue.category.name %>
  </p>
</header>

<div class="bg-white rounded-2xl border border-gray-200 p-6 max-w-xl">
  <%= form_with model: @resolution,
        url: officer_issue_resolution_path(@issue),
        local: true, class: "space-y-5" do |form| %>
    <% if @resolution.errors.any? %>
      <div role="alert" class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
        <p class="font-semibold mb-1">Please fix the following:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% @resolution.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :resolution_type_id, "Resolution", class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :resolution_type_id,
            @resolution_types.map { |rt| [rt.name, rt.id] },
            { include_blank: "Choose one…" },
            required: true,
            class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-4 pr-10 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 appearance-none bg-white bg-no-repeat bg-[right_1rem_center] bg-[length:1.25rem] bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20d%3D%22M19%209l-7%207-7-7%22/%3E%3C/svg%3E')]" %>
    </div>

    <div>
      <%= form.label :note, "Public note (optional)", class: "block text-sm font-medium text-gray-700" %>
      <p class="text-xs text-gray-500 mb-1.5">Visible to the resident who reported this issue.</p>
      <%= form.text_area :note, rows: 3, maxlength: 2_000,
            class: "block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :citation_number, "Citation number (internal)", class: "block text-sm font-medium text-gray-700" %>
      <p class="text-xs text-gray-500 mb-1.5">Not shown publicly. Leave blank if not applicable.</p>
      <%= form.text_field :citation_number, maxlength: 120,
            class: "block w-full rounded-lg border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="flex items-center justify-end gap-3 pt-2">
      <%= link_to "Cancel", officer_issue_path(@issue), class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
      <%= form.submit "Close issue",
            class: "rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
