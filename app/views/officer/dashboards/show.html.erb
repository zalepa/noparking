<% content_for(:title, "On shift") %>

<div data-controller="officer-location"
     data-officer-location-lat-value="<%= @coordinates&.first %>"
     data-officer-location-lng-value="<%= @coordinates&.last %>">

  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Nearby reports</h1>
    <p class="mt-2 text-sm text-gray-600">
      <% if @coordinates %>
        Sorted by distance from your current location.
      <% else %>
        Showing the most recent reports. Share your location to sort by distance.
      <% end %>
    </p>
  </header>

  <%# Location banner — different state based on whether we have coordinates %>
  <div class="mb-6 rounded-2xl border p-4 text-sm <%= @coordinates ? 'border-green-200 bg-green-50' : 'border-amber-200 bg-amber-50' %>">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 mt-0.5 shrink-0 <%= @coordinates ? 'text-green-600' : 'text-amber-600' %>"
           fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <div class="flex-1">
        <% if @coordinates %>
          <p class="font-semibold text-green-900">Location active</p>
          <p class="mt-0.5 text-green-800 text-xs">
            <%= number_with_precision(@coordinates.first, precision: 4) %>,
            <%= number_with_precision(@coordinates.last,  precision: 4) %>
          </p>
          <%= button_to "Refresh", "#",
                form: { data: { action: "officer-location#refresh" }, class: "inline" },
                class: "mt-2 text-xs font-semibold text-green-700 hover:text-green-800 bg-transparent border-0 p-0 cursor-pointer" %>
        <% else %>
          <p class="font-semibold text-amber-900" data-officer-location-target="message">Share your location</p>
          <p class="mt-0.5 text-amber-800 text-xs" data-officer-location-target="subtext">
            Tap below to allow location access so reports can be sorted by distance.
          </p>
          <button type="button" data-action="officer-location#request"
                  class="mt-2 rounded-lg bg-amber-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-amber-700">
            Share location
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <section class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
    <% if @issues.any? %>
      <ul class="divide-y divide-gray-100" data-officer-location-target="list">
        <% @issues.each do |issue| %>
          <%= render "officer/issues/issue_row", issue: issue, coordinates: @coordinates %>
        <% end %>
      </ul>
    <% else %>
      <p class="px-5 py-8 text-center text-sm text-gray-500">No reports yet.</p>
    <% end %>
  </section>
</div>
